model Notification {
    id BigInt @id @default(autoincrement())

    templateKey String @db.VarChar(200)
    payload     Json

    userId BigInt?
    user   User?   @relation(name:"UserTarget",fields: [userId], references: [id])

    targetRole String? @db.VarChar(50)

    clearedByID BigInt?
    clearedBy   User?   @relation(name: "ClearedBy", fields: [clearedByID], references: [id])

    isRead Boolean   @default(false)
    readAt DateTime?

    createdAt DateTime @default(now())

    @@index([userId, isRead])
    @@index([targetRole, isRead])
    @@map("notifications")
}
